# Notion Integration Token
# Create an integration at https://www.notion.so/my-integrations
# Give it read/write access to your workspace
NOTION_API_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Parent page ID where Spec Hub databases will be created
# This is the Notion page that will contain all Spec Hub databases
# Find it in the page URL: https://www.notion.so/Your-Page-{PAGE_ID}
NOTION_PARENT_PAGE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
